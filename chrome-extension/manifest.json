{
  "manifest_version": 3,
  "name": "Job Pipeline Capture",
  "version": "1.0",
  "description": "Save job postings directly to your recruiter pipeline.",
  "permissions": ["activeTab", "scripting", "storage", "identity", "alarms", "tabs"],
  "host_permissions": [
    "http://localhost:5001/*",
    "https://*/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "YOUR_GOOGLE_OAUTH_CLIENT_ID",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.profile",
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://boards.greenhouse.io/*",
        "*://job-boards.greenhouse.io/*",
        "*://jobs.lever.co/*",
        "*://jobs.ashbyhq.com/*",
        "*://*.myworkdayjobs.com/*",
        "*://*.myworkdaysite.com/*",
        "*://careers.smartrecruiters.com/*",
        "*://*.icims.com/*",
        "*://*.successfactors.com/*",
        "*://*.jobs2web.com/*",
        "*://jobs.jobvite.com/*",
        "*://*.taleo.net/*",
        "*://*.eightfold.ai/*",
        "*://*.avature.net/*",
        "*://*.phenompeople.com/*",
        "*://*.talentbrew.com/*",
        "*://app.jibecdn.com/*",
        "*://myjobs.adp.com/*",
        "*://*.oraclecloud.com/hcmUI/CandidateExperience/*",
        "*://www.linkedin.com/jobs/*",
        "*://www.indeed.com/viewjob*"
      ],
      "js": ["config.js", "content.js"],
      "css": ["overlay.css"]
    }
  ],
  "action": {
    "default_title": "Capture this job"
  }
}
